# --- Production (backend): MODERATION_STRICT=true, set VAPI_WEBHOOK_SECRET ---

# Qdrant (cloud or local via docker-compose)
# When using `docker-compose up`, the compose file sets QDRANT_URL=http://qdrant:6333 for the backend service.
# For Qdrant Cloud, set QDRANT_URL and QDRANT_API_KEY here; for local Qdrant without auth, QDRANT_API_KEY may be empty.
QDRANT_URL=https://your-qdrant-cluster.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

# --- LLM (OpenRouter, OpenAI-compatible) ---
# Cost per call is logged as `llm_usage` (see backend/services/llm_cost.py).
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_REFERRER=https://sahayaksetu.vercel.app
# OPENROUTER_APP_TITLE=SahayakSetu

# Public backend URL (Vapi webhooks, assistant config) — REQUIRED in production.
# In dev (ENV=development) these default to localhost; in production the app refuses
# to start without explicit values to prevent staging from silently using prod URLs.
BACKEND_URL=https://sahayaksetu-backend-3kxl.onrender.com
FRONTEND_ORIGIN=https://sahayak-setu.vercel.app
ALLOWED_ORIGINS=https://sahayak-setu.vercel.app
ALLOWED_ORIGIN_REGEX=^https://[a-z0-9-]+\.vercel\.app$
ENV=production

# Number of trusted reverse-proxy hops in front of the app (Render = 1, Cloudflare→Render = 2).
# Drives the rate limiter's choice of client IP from X-Forwarded-For. Defaults: prod=1, dev=0.
# TRUSTED_PROXY_COUNT=1

# Rate-limit storage. Defaults to Redis in production (memory in dev). Must match REDIS_URL
# unless RATE_LIMIT_STORAGE_URI is set explicitly.
# RATE_LIMIT_USE_REDIS=true
# RATE_LIMIT_STORAGE_URI=
# REDIS_URL=redis://your-redis-host:6379/0

# REQUIRED in production: HMAC validates incoming Vapi webhook bodies. Empty -> 503 in prod.
VAPI_WEBHOOK_SECRET=
# Signed webhook JSON: reject payloads older than skew (seconds). Optional strict timestamp.
# VAPI_WEBHOOK_MAX_SKEW_S=300
# VAPI_WEBHOOK_REQUIRE_TIMESTAMP=false

# Near-miss retrieval floor (default 0.15). Lower = more near-miss noise.
# NEAR_MISS_SCORE_FLOOR=0.15

# Moderation: true/1/yes = fail-closed on classifier JSON/call errors (recommended in production).
MODERATION_STRICT=true
# Structured LLM path (JSON schema + claims) with fallback to marker parsing.
LLM_JSON_MODE=false
# Retrieval blend: vector + keyword overlap (0.0..1.0 keyword weight)
HYBRID_RETRIEVAL=false
HYBRID_KEYWORD_WEIGHT=0.3
DEBUG_RETRIEVAL=false

# MongoDB — sessions, feedback, webhook nonces, voice-call follow-up cache, outcomes.
# REQUIRED in production (app refuses to start without it); optional in dev.
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=sahayaksetu

# REQUIRED in production: HMAC key for signing session user IDs. Empty -> users can
# impersonate each other by sending an arbitrary user_id. Use a long random string.
SESSION_SECRET=

# Action-plan LLM step (generate_agent_plan_json); prevents hung workers
# AGENT_PLAN_CALL_TIMEOUT_S=90

# Vapi dashboard
VAPI_API_KEY=your_vapi_api_key
VAPI_ASSISTANT_ID=
