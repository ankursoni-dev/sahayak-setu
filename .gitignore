# SahayakSetu Project Ignores

# Environment (all variants — .env, .env.local, .env.backup, .env.*)
# Negation keeps the committed example files tracked.
.env
.env.*
*.env
!.env.example
!frontend/.env.example
sahayak_env/
venv/
.venv/
__pycache__/
*.pyc

# Logs (apps write to .backend.log, .frontend.log, .runtime/* at runtime)
*.log
.runtime/

# Local-only assets / screenshots / design notes / scratch
_local/

# Data & Database
qdrant_storage/
*.db
*.sqlite

# IDEs & System
.vscode/
.idea/
.DS_Store
Thumbs.db

# Claude Code per-machine settings (project policy in committed settings.json,
# personal allow-list / preferences in settings.local.json — local only).
.claude/settings.local.json

# Build & Scripts
dist/
build/
*.exe
scripts/*.exe
node_modules/
playwright-report/
test-results/
.playwright/
data/
prompts/