# Override defaults if needed. All keys are public (shipped in bundle).
# VITE_BACKEND_URL=http://localhost:8000
# VITE_VAPI_PUBLIC_KEY=
# VITE_VAPI_ASSISTANT_ID=
# Set to "false" to disable Vapi SDK entirely and force browser SpeechRecognition.
# Useful in dev when the baked-in Vapi keys aren't valid for your account.
# VITE_VAPI_ENABLED=false
